<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true" android:drawable="@drawable/bg_tv_accent_panel" />
    <item android:state_selected="true" android:drawable="@drawable/bg_tv_accent_panel" />
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:endColor="#8A171C22"
                android:startColor="#B83C434B"
                android:type="linear" />
            <stroke
                android:width="1dp"
                android:color="@color/tv_stroke_focus" />
            <corners android:radius="22dp" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#70101215"
                android:startColor="#8A20252B"
                android:type="linear" />
            <stroke
                android:width="1dp"
                android:color="#20FFFFFF" />
            <corners android:radius="22dp" />
        </shape>
    </item>
</selector>
