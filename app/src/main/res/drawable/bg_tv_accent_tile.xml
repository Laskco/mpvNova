<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true" android:drawable="@drawable/bg_tv_accent_panel" />
    <item android:state_selected="true" android:drawable="@drawable/bg_tv_accent_panel" />
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:endColor="?attr/mpvAccentDeep"
                android:startColor="?attr/mpvAccent"
                android:type="linear" />
            <stroke
                android:width="1dp"
                android:color="?attr/mpvStrokeFocus" />
            <corners android:radius="22dp" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="?attr/mpvSurfaceAltEnd"
                android:startColor="?attr/mpvSurfaceAltStart"
                android:type="linear" />
            <stroke
                android:width="1dp"
                android:color="?attr/mpvStroke" />
            <corners android:radius="22dp" />
        </shape>
    </item>
</selector>
