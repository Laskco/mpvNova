<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#8A1A1D21"
                android:startColor="#A02C3137"
                android:type="linear" />
            <stroke android:width="1dp" android:color="@color/tv_stroke_focus" />
            <corners android:radius="18dp" />
        </shape>
    </item>

    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/tv_focus_wash_soft" />
            <corners android:radius="18dp" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#70101215"
                android:startColor="#8A20252B"
                android:type="linear" />
            <stroke android:width="1dp" android:color="#20FFFFFF" />
            <corners android:radius="18dp" />
        </shape>
    </item>
</selector>
