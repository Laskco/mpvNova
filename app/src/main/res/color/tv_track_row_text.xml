<?xml version="1.0" encoding="utf-8"?>
<!-- Text color for track-picker rows. When the row is on the bright pill
     (state_checked), text flips dark for legibility; default is white. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true" android:color="@color/tv_text" />
    <item android:state_checked="true" android:color="#FF141421" />
    <item android:color="@color/tv_text" />
</selector>
