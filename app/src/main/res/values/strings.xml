    <string name="decoder_mode_hw_plus_description">Uses the direct mediacodec path. Fastest when it works, but it can be pickier on some files and devices.</string>
    <string name="decoder_mode_hw_description">Uses mediacodec-copy, copying decoded frames back before rendering. Usually the safest hardware path.</string>
    <string name="decoder_mode_sw_description">Turns hardware decode off and uses ffmpeg software decoding. Most compatible, but much heavier on the CPU.</string>
    <string name="decoder_mode_gnext_description">Uses the gpu-next renderer with mediacodec-copy. This keeps libplacebo rendering while avoiding the fragile direct hardware path.</string>
    <string name="decoder_mode_shield_h10p_description">Shield-specific fallback for anime and other Hi10P x264 files: gpu-next plus software decode, 6 lavc threads, faster skiploopfilter tuning, display-resample sync, and a smaller cache.</string>
    <string name="pref_preferred_decoder_mode_message">Pick the default video decode path used when Automatic decoder fallback is off. This controls both how frames are decoded and which renderer path mpvNova starts with.</string>
